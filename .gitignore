# ========================
# .gitignore - Projeto Mixer de Áudio
# ========================

# Arquivos de Sistema Operacional (Windows/Mac/Linux)
.DS_Store
Thumbs.db
*~

# Python (Cliente)
__pycache__/
*.py[cod]
*$py.class
venv/
.env

# Go (Servidor)
/bin/
*.exe
*.test
*.out

# Arquivos de Áudio (Testes e Gravações locais)
*.wav
*.mp3
*.raw
*.pcm
/recordings/

# IDEs
.vscode/
.idea/